{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Turbo the Cat",
  "version": "0.1.0",
  "identifier": "uk.co.simplysim.turbothecat",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "node_modules/.bin/vite",
    "beforeBuildCommand": "node_modules/.bin/tsc && node_modules/.bin/vite build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Turbo the Cat",
        "width": 100,
        "height": 100,
        "minWidth": 100,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false,
        "skipTaskbar": true,
        "center": false,
        "visibleOnAllWorkspaces": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
